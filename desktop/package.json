{
  "name": "smartbiz-desktop",
  "version": "1.0.0",
  "description": "SmartBiz - Business Management System Desktop App",
  "main": "main.js",
  "author": "SmartBiz",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.smartbiz.desktop",
    "productName": "SmartBiz",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "icons/**/*"
    ],
    "win": {
      "target": ["portable"],
      "icon": "icons/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icons/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icons/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "installer-check.nsh"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
